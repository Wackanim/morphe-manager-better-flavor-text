    <!-- Home Screen - Home Greetings -->
    <string name="home_greeting_1">Kokią programėlę norėtumėte pataisyti?</string>
    <!-- Humorous hype message with light nostalgia -->
    <string name="home_greeting_2">Ar norite padaryti programas vėl legendinėmis?</string>
    <!-- "Buckle up" referring to fastening your vehicle seat belt. A light-hearted joke to build excitement -->
    <string name="home_greeting_3">Susisegėkite, metas pataisyti</string>
    <!-- Sarcastic joke about blocking ads, intentionally over-the-top -->
    <string name="home_greeting_4">Dar viena diena, dar vienas šedevras be reklamų</string>
    <!-- "Watch ads" refers to watching video ads in unpatched apps -->
    <string name="home_greeting_5">Norite žiūrėti reklamas? Aš irgi ne</string>
    <!-- Friendly, slightly mischievous joke about controlling app behavior -->
    <string name="home_greeting_6">Priverskime programėles elgtis</string>
    <!-- Whimsical forecast-style joke, not meant literally -->
    <string name="home_greeting_7" formatted="false">Šiandienos prognozė: 100 % tikimybė pataisų</string>
    <!-- From mediocrity to amazing -->
    <string name="home_greeting_8">Ar esate pasiruošę nepribloškiančio paversti nuostabiu?</string>
    <!-- Playful exaggeration, making patching feel heroic -->
    <string name="home_greeting_9">Saugome programas nuo pačių saves nuo šiandien</string>
    <!-- Light sarcasm, casual and tech-savvy humor -->
    <string name="home_greeting_10">Veikia nuo kofeino ir gerų pataisų</string>
